# Server
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# Database — use sqlite for local dev, mysql for production
DB_DIALECT=sqlite
DB_STORAGE=./kyc-dev.sqlite
# For MySQL set these instead:
# DB_DIALECT=mysql
# DB_HOST=localhost
# DB_PORT=3306
# DB_NAME=kyc
# DB_USER=kyc
# DB_PASSWORD=kyc

# Auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=1h

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
